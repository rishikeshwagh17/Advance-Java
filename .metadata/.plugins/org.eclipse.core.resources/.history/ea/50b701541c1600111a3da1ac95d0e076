package tester;

import java.sql.Date;
import java.util.List;
import java.util.Scanner;

import dao.EmployeeDaoImpl;
import pojos.Employee;

public class TestEmpCRUD {

	public static void main(String[] args) {
		try(Scanner sc = new Scanner(System.in)){
			//create emp dao instance: init phase of hte application
			EmployeeDaoImpl dao = new EmployeeDaoImpl();
			boolean exit = false;
			while(!exit) {
				System.out.println("1.Get Emp Details 2.insert Emp Details 3.update emp details 4.Delete Emp 10.Exit");
				try {
					switch (sc.nextInt()) {
					case 1:{
						System.out.println("Enter dept beginDate & endDate(yr-mon-day)");
						List<Employee> empList = dao.getSelectedEmpDetails(sc.next(), Date.valueOf(sc.next()), Date.valueOf(sc.next()));
						empList.forEach(System.out::println);
						break;
					}
					case 2:{
						System.out.println("Enter the employee details : name  addr  salary  deptid  join_date(yr-mon-day) ");
						System.out.println(dao.insertEmpDetails(new Employee(sc.next(), sc.next(), sc.nextDouble(), sc.next(), Date.valueOf(sc.next()))));
						break;
					}
					case 3:{
						System.out.println("Enter the employee details to update: empId,  salInc,  newDept");
						System.out.println( dao.updateEmpDetails(sc.nextInt(), sc.nextDouble(), sc.next()));
						break;
					}
					case 4:{
						System.out.println("Enter the emp id to delete");
						System.out.println(dao.deleteEmployee(sc.nextInt()));
						break;
					}
					case 10:
						exit = true;
						//destroy phase of app
						dao.cleanUp();
						break;
					}
				}catch (Exception e) {
					e.printStackTrace();
				}
			}
			
		}catch (Exception e) {
			e.printStackTrace();
		}

	}

}

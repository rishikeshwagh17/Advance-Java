package dao;

import java.sql.*;
import java.sql.SQLException;

import utils.DBUtils;

public class AccountDaoImpl implements IAccountDao {

	private Connection cn;
	private CallableStatement cst1;

	public AccountDaoImpl() throws SQLException {
		cn = DBUtils.openConnection();
		// cst: to represent invocation of a store procedure
		cst1 = cn.prepareCall("{call transfer_funds(?,?,?,?,?)}");

		// register OUT params for procedure
		// API - public void registerOutParamter(int paramPos, int jdbcType) throws
		// SQLExcpetion
		cst1.registerOutParameter(1, Types.DOUBLE); // for double amount sbal
		cst1.registerOutParameter(2, Types.DOUBLE); // for dbal
		System.out.println("Account Dao created...");
	}

	@Override
	public String transferFunds(int srcAcctNo, int destAcctNo, double amount) throws SQLException {
		//set IN params
		cst1.setInt(1, srcAcctNo);
		cst1.setInt(2, destAcctNo);
		cst1.setDouble(3, amount);
		//execute the stored procedure
		cst1.execute();
		return null;
	}

	public void cleanUp() throws SQLException {
		if (cst1 != null)
			cst1.close();
		if(cn != null)
			cn.close();
		System.out.println("Account DAO closed...");
	}

}

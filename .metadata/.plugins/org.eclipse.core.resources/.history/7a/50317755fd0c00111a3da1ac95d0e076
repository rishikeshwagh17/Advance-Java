package tester;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.Scanner;
import static utils.DBConnectionUtil.getDBConnection;

public class TestTopicTutorial {

	public static void main(String[] args) {
		
		String sql = "select * from users where email=? and password=?";
		
		//make a scanner and then create a connection
		try(Scanner sc = new Scanner(System.in);
				Connection cn = getDBConnection();
					PreparedStatement pst = 	cn.prepareStatement(sql)){
			System.out.println("Please enter the email and password");
			String email = sc.next();
			String password = sc.next();
			
			//now use this values as a input to the query execution
			pst.setString(1, email);
			pst.setString(2, password);
			
			try(ResultSet rst =  pst.executeQuery()){
				while(rst.next()) {
					System.out.println("detail of user id %d name %s email %.1f reg_amt %s  reg_date %s role  ", rst.getInt(1), rst.getString(2),rst.get);
				}
			}
			
		}catch (Exception e) {
			e.printStackTrace();
		}

	}

}

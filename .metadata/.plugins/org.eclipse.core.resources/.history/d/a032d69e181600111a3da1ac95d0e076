package dao;

import java.sql.*;
import java.util.ArrayList;
import java.util.List;

import pojos.Employee;
import static utils.DBUtils.openConnection;

public class EmployeeDaoImpl implements IEmployeeDao {

	private Connection cn;
	private PreparedStatement pst1,pst2,pst3,pst4;
	
	
	//constr -- init time jobs (cn,pst,csts)
	//clean-up - close PST/STs/CSTs/cn
	
	public EmployeeDaoImpl() throws SQLException {
		// get fix DB connection from DBUtils
		cn = openConnection();
		pst1 = cn.prepareStatement("select empid,name,salary,join_date from my_emp where deptid=? and join_date between ? and ?");
		
		pst2 = cn.prepareStatement("insert into my_emp values(default,?,?,?,?,?)");
		pst3 = cn.prepareStatement("update my_emp set salary=salary+?, deptid=?  where empid=?");
		pst4 = cn.prepareStatement("delete from my_emp where empid=?")
		System.out.println("Employee Dao created...");
	}
	
	
	@Override
	public List<Employee> getSelectedEmpDetails(String deptId, Date strDate, Date endDate) throws SQLException {
		//creating the list to store resultSet data
		List<Employee> emps= new ArrayList<>();
		// how can we access details
		//Set IN parameters
		pst1.setString(1, deptId);
		pst1.setDate(2, strDate);
		pst1.setDate(3, endDate);
		try(ResultSet rst = pst1.executeQuery()){
			while(rst.next()) {
				emps.add(new Employee(rst.getInt(1), rst.getString(2), rst.getDouble(3), rst.getDate(4)));
			}
		}
		return emps;
	}
	
	
	@Override
	public String insertEmpDetails(Employee emp) throws SQLException {
		// insert the employee details
		//set IN param -  name    | addr    | salary | deptid | join_date
		pst2.setString(1, emp.getName());
		pst2.setString(2, emp.getAddress());
		pst2.setDouble(3, emp.getSalary());
		pst2.setString(4, emp.getDeptId());
		pst2.setDate(5, emp.getJoinDate());
		//execute query: insert DML : method of PST : public int executeUpdate() throws SQLException
		int updateCount = pst2.executeUpdate();
		if(updateCount == 1)
			return "Employee details inserted....";
		return "Emp details insertion failed....";
	}

	
	//method to update emp details
	@Override
	public String updateEmpDetails(int empId, double salInc, String newDept) throws SQLException {
		//set IN params 1.salInc 2.deptId 3. empId
		pst3.setDouble(1, salInc);
		pst3.setString(2, newDept.toLowerCase());
		pst3.setInt(3, empId);
		int updateCount = pst3.executeUpdate();
		if(updateCount == 1)
			return "Employee details updated....";
		return "Emp details updation failed....";
	}


	//add a method to cleanUp database resources
	public void cleanUp() throws SQLException {
		if(pst1 != null) {
			pst1.close();
		}
		if(pst2 != null) {
			pst2.close();
		}
		if(pst3 != null)
			pst3.close();
		if(cn != null) {
			cn.close();
		}
		System.out.println("Employee Dao cleanup");
	}

}
